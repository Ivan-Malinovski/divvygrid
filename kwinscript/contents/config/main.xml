<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd" >
    <kcfgfile name=""/>
    <group name="">

        <entry name="gridCols" type="Int">
            <default>6</default>
        </entry>

        <entry name="gridRows" type="Int">
            <default>4</default>
        </entry>

        <!-- Int, not String: a plain QComboBox's auto-bindable USER property is
             currentIndex, not currentText, so a String-typed entry ends up storing the
             index as text ("0"/"1") instead of matching by name - confirmed live, this
             silently broke mode-switching entirely. Mapped to/from the mode name in
             main.qml's loadConfig(). -->
        <entry name="mode" type="Int">
            <default>0</default>
        </entry>

        <entry name="compactWidth" type="Int">
            <default>480</default>
        </entry>

        <entry name="compactHeight" type="Int">
            <default>300</default>
        </entry>

        <entry name="gap" type="Int">
            <default>8</default>
        </entry>

        <entry name="resizeOverlapping" type="Bool">
            <default>true</default>
        </entry>

        <!-- when a placement completely covers another window - which resizeOverlapping's
             edge-slice shrink cannot handle, so the window ends up hidden underneath -
             move that window to the largest free grid region instead. -->
        <entry name="relocateCovered" type="Bool">
            <default>true</default>
        </entry>

        <entry name="compactAtCursor" type="Bool">
            <default>false</default>
        </entry>

        <!-- compact mode only: draw a 1:1 outline of the resulting window rectangle on the
             real screen while selecting, since the compact grid is a miniature and gives no
             sense of the final size on its own. -->
        <entry name="ghostPreview" type="Bool">
            <default>true</default>
        </entry>

        <!-- Int for the same reason as "mode" above - see comment there. -->
        <entry name="hotCorner" type="Int">
            <default>0</default>
        </entry>

        <!-- per-output grid column/row overrides, keyed by KWin output name (e.g. "DP-2").
             Free-form text since kcfg has no native map type - same pattern as kzones'
             layoutsJson. Preferred syntax is one "DP-2 = 8x6" per line; the original JSON
             object form ({"DP-2":{"gridCols":8,"gridRows":6}}) is still parsed for
             existing installs. See parseMonitorOverrides() in main.qml. Kept named
             monitorsJson so already-stored values keep resolving. -->
        <entry name="monitorsJson" type="String">
            <default></default>
        </entry>

        <!-- opt-in: auto-shows a small top-center single-cell picker on any native window
             drag past a distance threshold, no shortcut needed - see main.qml's "auto-trigger
             on drag" section. -->
        <entry name="dragAutoTrigger" type="Bool">
            <default>false</default>
        </entry>

        <!-- When true, the auto-trigger picker spawns centered on the cursor instead of
             pinned to top-center of the work area. Kept separate from compactAtCursor
             (which only affects non-autoMode compact activations) so each mode's
             positioning can be tuned independently. -->
        <entry name="autoAtCursor" type="Bool">
            <default>false</default>
        </entry>

        <!-- opt-in: when interactively resizing a window, any window whose opposite edge
             sits flush against the dragged edge follows it, so the shared border between
             two tiled windows moves as one (the Windows Snap behaviour). See main.qml's
             "linked resize" section. -->
        <entry name="linkedResize" type="Bool">
            <default>false</default>
        </entry>

        <!-- opt-in, Windows-Snap style: a plain NATIVE mouse window drop with the cursor
             against a screen edge fills the largest reachable free area containing the
             window's cells, or takes the half toward the edge on an empty screen - a shadowed
             preview is shown while armed. Deliberately does NOT fire on a grid-overlay drop
             (that commits exactly the selected size; use Meta+Alt+E for an explicit fill).
             Off by default - the user typically also disables KWin's ElectricBorder snap,
             since both firing on the same edge is the failure mode. Threshold is hardcoded,
             not kcfg-tunable. Skipped while dragAutoTrigger is on (that picker owns the drag). -->
        <entry name="autoExpandOnEdgeDrag" type="Bool">
            <default>false</default>
        </entry>

        <!-- opt-in: after a grid/compact-picker placement, close any small leftover gap to a
             neighbour (e.g. a neighbour that was itself resized off-grid, so the tiler's usual
             edge-to-edge spacing doesn't hold). Does NOT trigger on a plain native window
             resize - that has nothing to do with VibeTiles. Only closes gaps up to a small
             cap - genuinely filling free space still needs Meta+Alt+E or
             autoExpandOnEdgeDrag. See main.qml's snapWindowGaps(). -->
        <entry name="snapGaps" type="Bool">
            <default>false</default>
        </entry>

        <!-- how far (px) a snapGaps edge is allowed to grow to close a gap. Keeps the feature
             a gap-closer rather than a second expand-to-fill trigger - see snapWindowGaps(). -->
        <entry name="snapGapMax" type="Int">
            <default>200</default>
        </entry>

    </group>
</kcfg>
